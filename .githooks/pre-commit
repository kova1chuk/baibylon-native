#!/bin/sh

echo "🔄 Pre-commit: Running linting and formatting checks..."

echo "📝 Checking code with oxlint..."
pnpm exec oxlint

if [ $? -ne 0 ]; then
  echo "❌ Pre-commit: oxlint found issues. Please fix them before committing."
  exit 1
fi

echo "🎨 Checking code formatting with oxfmt..."
pnpm exec oxfmt --check .

if [ $? -ne 0 ]; then
  echo "❌ Pre-commit: oxfmt found formatting issues. Run 'pnpm format' to fix them."
  exit 1
fi

echo "✅ Pre-commit: All checks passed!"
