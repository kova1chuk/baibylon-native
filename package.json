{
  "name": "vocairo",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "type-check": "tsgo --noEmit",
    "check": "run-p type-check lint format:check",
    "sync:i18n": "cp ../vocairo-ai-tutor-nest/public/locales/en.json i18n/locales/en.json",
    "prepare": "git config core.hooksPath .githooks",
    "supabase:types": "supabase gen types typescript --linked > types/supabase.ts",
    "supabase:types:project": "supabase gen types typescript --project-id",
    "build:android": "eas build --platform android --profile production",
    "build:android:dev": "eas build --platform android --profile development",
    "build:ios": "eas build --platform ios --profile production",
    "build:ios:dev": "eas build --platform ios --profile development",
    "build:all": "eas build --platform all --profile production",
    "build:all:dev": "eas build --platform all --profile development",
    "deploy:android": "eas submit --platform android --profile production",
    "deploy:ios": "eas submit --platform ios --profile production",
    "deploy:all": "eas submit --platform all --profile production"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.1.0",
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/elements": "^2.3.8",
    "@react-navigation/native": "^7.1.6",
    "@reduxjs/toolkit": "^2.11.2",
    "@supabase/supabase-js": "^2.89.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "expo": "~53.0.27",
    "expo-application": "^6.1.5",
    "expo-auth-session": "^6.2.1",
    "expo-av": "^15.1.7",
    "expo-blur": "~14.1.5",
    "expo-build-properties": "~0.14.8",
    "expo-constants": "~17.1.8",
    "expo-crypto": "^14.1.5",
    "expo-dev-client": "~5.2.4",
    "expo-font": "~13.3.2",
    "expo-haptics": "~14.1.4",
    "expo-image": "~2.4.1",
    "expo-linear-gradient": "^14.1.5",
    "expo-linking": "~7.1.7",
    "expo-localization": "^16.1.6",
    "expo-router": "~5.1.11",
    "expo-secure-store": "^14.2.4",
    "expo-splash-screen": "~0.30.10",
    "expo-status-bar": "~2.2.3",
    "expo-symbols": "~0.4.5",
    "expo-system-ui": "~5.0.11",
    "expo-updates": "~0.28.18",
    "expo-web-browser": "~14.2.0",
    "i18next": "^25.8.13",
    "i18next-http-backend": "^3.0.2",
    "lucide-react-native": "^0.575.0",
    "nativewind": "^4.2.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-i18next": "^16.5.4",
    "react-native": "0.79.6",
    "react-native-css-interop": "^0.2.1",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-mmkv": "^4.1.2",
    "react-native-nitro-modules": "^0.34.1",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "^15.11.2",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.20.0",
    "react-native-webview": "13.13.5",
    "react-redux": "^9.2.0",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@nkzw/oxlint-config": "^1.0.1",
    "@types/react": "~19.0.10",
    "@typescript/native-preview": "7.0.0-dev.20260302.1",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "supabase": "^2.70.5",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.8.3"
  },
  "packageManager": "pnpm@10.24.0"
}
