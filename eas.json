{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "credentialsSource": "local"
    },
    "preview": {
      "distribution": "internal",
      "credentialsSource": "local"
    },
    "preview-lite": {
      "distribution": "internal",
      "credentialsSource": "local",
      "env": {
        "EAS_BUILD_PROFILE": "preview-lite"
      }
    },
    "production": {
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
